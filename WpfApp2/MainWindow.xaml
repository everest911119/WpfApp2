<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        xmlns:converters="clr-namespace:WpfApp2.Converters"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800">
    <Window.Resources>
        <converters:LengthMmConverter x:Key="LengthMmConverter" />
        <Style TargetType="GroupBox">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   FontWeight="SemiBold" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF2D2D2D" Padding="12">
            <TextBlock x:Name="HeaderTextBlock"
                       Foreground="White"
                       TextAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Text="{Binding HeaderText}" />
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Header="====Metric====" Grid.Row="0">
                <DataGrid x:Name="DATA_GRID"
                          AutoGenerateColumns="False"
                          Background="LightGray"
                          ItemsSource="{Binding Items}" 
                          CanUserSortColumns="False"
                          >
                    <DataGrid.InputBindings>
                        <KeyBinding Key="Enter"
                                    Command="{Binding UpdateLengthCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=DATA_GRID}" />
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"  IsReadOnly="True" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*"   />
                        <DataGridTextColumn Header="LengthMm" Binding="{Binding LengthMm,Converter={StaticResource LengthMmConverter}, UpdateSourceTrigger=PropertyChanged}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding LengthMm, Converter={StaticResource LengthMmConverter}}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="2*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Gray" />

            <GroupBox Header="===Imperial====" Grid.Row="2">
                <DataGrid x:Name="DATA_GRID_SECOND"
                          AutoGenerateColumns="False"
                          Background="LightGray"
                          CanUserSortColumns="False"
                          IsReadOnly="True"
                          
                          ItemsSource="{Binding Items}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                        <DataGridTextColumn Header="LengthMm" Binding="{Binding LengthInch}" Width="2*" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="130,10,0,10" Width="660">
            <Button x:Name="LoadButton"
                    Content="Load Data"
                    Margin="10"
                    Padding="12,6"
                    Height="25"
                    Width="406"
                    Command="{Binding LoadCommand}" />
            <Button Content="Export To CSV"
                    Margin="0,0,0,6"
                    Padding="8,2"
                    Command="{Binding ExportCommand}" />
            <Button Content="Recalc Button"
                    Margin="0,0,0,6"
                    Padding="8,2"
                    Command="{Binding RecalcCommand}" />
        </StackPanel>
    </Grid>
</Window>
